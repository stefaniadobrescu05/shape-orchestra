<?xml version="1.0"?>
<OSCOutputGroup>
  <oscMessage>/shape/control</oscMessage>
  <hostName>localhost</hostName>
  <outputPort>12000</outputPort>
  <outputs class="linked-list">
    <wekimini.osc.OSCClassificationOutput>
      <name>state</name>
      <numClasses>4</numClasses>
      <isSendingDistribution>false</isSendingDistribution>
    </wekimini.osc.OSCClassificationOutput>
    <wekimini.osc.OSCNumericOutput>
      <name>intensity</name>
      <min>0.0</min>
      <max>1.0</max>
      <outputType>REAL</outputType>
      <limitType>SOFT</limitType>
      <trainingDataLimitRestriction>DONT_ENFORCE_LIMITS</trainingDataLimitRestriction>
      <trainingDataIntegerRestriction>DONT_ENFORCE_INTEGER</trainingDataIntegerRestriction>
    </wekimini.osc.OSCNumericOutput>
  </outputs>
</OSCOutputGroup>